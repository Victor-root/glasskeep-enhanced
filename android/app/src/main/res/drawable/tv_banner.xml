<?xml version="1.0" encoding="utf-8"?>
<!-- 320x180 banner for Android TV Leanback launcher.
     Built as a layer-list so we don't ship a PNG and stay sharp at any
     density. Three layers:
       1. Deep gradient background with rounded corners
       2. Soft violet radial halo behind the logo
       3. The GlassKeep mark, generously inset -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 1) Rounded gradient backdrop. Diagonal indigo→violet→deep-purple
            matches the in-app login title gradient. -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#0b0d12"
                android:centerColor="#1a1530"
                android:endColor="#3b1f7a" />
        </shape>
    </item>

    <!-- 2) Radial violet halo, slightly off-center so the composition
            feels less symmetrical / more polished. -->
    <item
        android:left="60dp"
        android:top="18dp"
        android:right="60dp"
        android:bottom="18dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="90dp"
                android:startColor="#9061f0"
                android:centerColor="#5b21b6"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- 3) GlassKeep logo, generously inset to leave breathing room
            around the mark. -->
    <item
        android:left="92dp"
        android:top="22dp"
        android:right="92dp"
        android:bottom="22dp"
        android:drawable="@drawable/glasskeep_logo" />

</layer-list>
