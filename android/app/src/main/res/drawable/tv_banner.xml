<?xml version="1.0" encoding="utf-8"?>
<!--
  Android TV launcher banner â€” 320x180. Three layers:
    1. Rounded indigoâ†’violet gradient backdrop.
    2. Original app logo (PNG), centred a bit above the middle to
       leave room for the wordmark beneath.
    3. "GlassKeep" wordmark rendered with a real font (DejaVu Sans
       Bold) at 4x density so it stays crisp on 4K panels.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 1. Rounded gradient backdrop. -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#6366f1"
                android:endColor="#7c3aed" />
        </shape>
    </item>

    <!-- 2. App logo, 80dp square, centred horizontally and pushed up
            from the middle so the wordmark fits underneath.
            (banner 320x180, logo 80x80) â†’ left/right insets 120,
            top inset 14, bottom inset 86 = 180-14-80. -->
    <item
        android:left="120dp"
        android:top="14dp"
        android:right="120dp"
        android:bottom="86dp"
        android:drawable="@drawable/glasskeep_logo" />

    <!-- 3. Wordmark PNG (xxxhdpi 880x140 â†’ ~220x35 dp), positioned
            below the logo with a small gap. Centred horizontally.
            (top 108, bottom 38 = 180-108-34 â‰ˆ wordmark height). -->
    <item
        android:left="50dp"
        android:top="108dp"
        android:right="50dp"
        android:bottom="38dp"
        android:drawable="@drawable/tv_banner_wordmark"
        android:gravity="center" />

</layer-list>
