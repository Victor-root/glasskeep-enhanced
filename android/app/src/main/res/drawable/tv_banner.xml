<?xml version="1.0" encoding="utf-8"?>
<!--
  Android TV launcher banner ‚Äî 320x180.
  Two layers:
    1. Rounded indigo‚Üíviolet gradient backdrop (same diagonal sweep
       as the app's .btn-gradient buttons).
    2. The original app logo PNG, centered with generous side insets
       so it reads as a clean badge over the gradient.

  No wordmark inside the banner ‚Äî the Leanback launcher will display
  the app label ("GlassKeep") underneath the banner automatically.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 1. Rounded gradient backdrop. -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#6366f1"
                android:endColor="#7c3aed" />
        </shape>
    </item>

    <!-- 2. App logo, kept square (~140dp tall) and centered. With a
            16:9 banner that means roughly 90dp of horizontal inset on
            each side and 20dp top/bottom ‚Äî leaves a tasteful ring of
            gradient around the logo. -->
    <item
        android:left="90dp"
        android:top="20dp"
        android:right="90dp"
        android:bottom="20dp"
        android:drawable="@drawable/glasskeep_logo" />

</layer-list>
