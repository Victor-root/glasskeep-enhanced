<?xml version="1.0" encoding="utf-8"?>
<!--
    Foreground layer for the "new text note" shortcut. White glyph
    centred in the 108×108 canvas's adaptive-icon safe zone (the
    inner 72×72 square, x=18..90 / y=18..90). Outside the safe zone
    the launcher may crop; staying inside guarantees the icon
    renders identically on every launcher.
    scale = 72/24 = 3   →   icon fills the safe zone exactly
    translate = (108 - 72)/2 = 18
-->
