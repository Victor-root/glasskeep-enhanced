    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:translateX="18"
        android:translateY="18"
        android:scaleX="3"
        android:scaleY="3">
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M19,3H5c-1.1,0 -2,0.9 -2,2v14c0,1.1 0.9,2 2,2h14c1.1,0 2,-0.9 2,-2V5c0,-1.1 -0.9,-2 -2,-2zm0,16H5V5h14v14zm-2,-6H7v-2h10v2zm-4,4H7v-2h6v2zm4,-8H7V7h10v2z" />
    </group>
</vector>
