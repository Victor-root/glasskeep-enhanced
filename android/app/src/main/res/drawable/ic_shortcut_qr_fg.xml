<?xml version="1.0" encoding="utf-8"?>
<!--
    Foreground layer for "Scan QRCODE". The QR pattern's raw paths
    span 27..81 (54 units) in their own coordinate space; scaling by
    72/54 = 1.333× and re-centring places the whole thing inside the
    108×108 safe zone (18..90).
    scaleX = scaleY = 1.333
    To send (27,27) → (18,18): translate = 18 - 27 × 1.333 = -18
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:translateX="-18"
        android:translateY="-18"
        android:scaleX="1.333"
        android:scaleY="1.333">
        <!-- Top-left finder pattern: outer 18, hole 12, dot 6 -->
        <path
            android:fillColor="#FFFFFF"
            android:fillType="evenOdd"
            android:pathData="M27,27 h18 v18 h-18 z M30,30 h12 v12 h-12 z M33,33 h6 v6 h-6 z" />
        <!-- Top-right finder pattern -->
        <path
            android:fillColor="#FFFFFF"
            android:fillType="evenOdd"
            android:pathData="M63,27 h18 v18 h-18 z M66,30 h12 v12 h-12 z M69,33 h6 v6 h-6 z" />
        <!-- Bottom-left finder pattern -->
        <path
            android:fillColor="#FFFFFF"
            android:fillType="evenOdd"
            android:pathData="M27,63 h18 v18 h-18 z M30,66 h12 v12 h-12 z M33,69 h6 v6 h-6 z" />
        <!-- Scattered data cells in the bottom-right quadrant -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M51,51 h6 v6 h-6 z M63,51 h6 v6 h-6 z M75,51 h6 v6 h-6 z M57,63 h6 v6 h-6 z M69,63 h6 v6 h-6 z M51,69 h6 v6 h-6 z M75,75 h6 v6 h-6 z M63,75 h6 v6 h-6 z" />
    </group>
</vector>
